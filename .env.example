# NEXIRE — Environment Variables Reference
# Copy this file to .env.local for local development.
# NEVER commit .env.local to version control.
# Last updated: 2026-03-06

# ─────────────────────────────────────────────────
# SUPABASE (required)
# ─────────────────────────────────────────────────

# Public URL of your Supabase project (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=https://zbzwdxcarmoeyicaplbn.supabase.co

# Public anon key (safe in client — RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpiendkeGNhcm1vZXlpY2FwbGJuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI3ODk4NTEsImV4cCI6MjA4ODM2NTg1MX0.ZmmR_MFRxJ3q3aIKJi6zeUYvk8xDvNoX8KHDFDpsR8w

# Service role key — SERVER-SIDE ONLY. Never use NEXT_PUBLIC_ prefix.
# Used for admin operations (bypasses RLS). Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpiendkeGNhcm1vZXlpY2FwbGJuIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3Mjc4OTg1MSwiZXhwIjoyMDg4MzY1ODUxfQ.TBaZeOGcHlU5isO53yt45-5qYQvRTnfjBUSFyVB3yvA

# ─────────────────────────────────────────────────
# PROSPEO (required)
# ─────────────────────────────────────────────────

# Prospeo API key — SERVER-SIDE ONLY. Never expose to client.
# Used exclusively via lib/prospeo/client.ts
PROSPEO_API_KEY=your_prospeo_api_key

# ─────────────────────────────────────────────────
# CRUSTDATA (required)
# ─────────────────────────────────────────────────

# CrustData API key — SERVER-SIDE ONLY.
# Used for profile search and candidate data retrieval.
CRUSTDATA_API_KEY=your_crustdata_api_key

# ─────────────────────────────────────────────────
# UPSTASH REDIS — Cache + Rate Limiting (required)
# ─────────────────────────────────────────────────

# Upstash Redis REST URL (per-user rate limits + search cache)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io

# Upstash Redis REST token
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ─────────────────────────────────────────────────
# RAZORPAY — Payments (required for billing module)
# ─────────────────────────────────────────────────

RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─────────────────────────────────────────────────
# RESEND — Email Sending (required)
# ─────────────────────────────────────────────────

# Resend API key — for sequences, magic links, and invitations
RESEND_API_KEY=re_your_resend_api_key

# Verified "from" email address in Resend
RESEND_FROM_EMAIL=noreply@nexire.in

# ─────────────────────────────────────────────────
# APP CONFIG (required)
# ─────────────────────────────────────────────────

# Public base URL of the app (used for share links, OG images, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────
# ANALYTICS (optional but recommended)
# ─────────────────────────────────────────────────

# PostHog project API key (public, safe in client)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key

# Sentry DSN for error tracking (server-side only)
SENTRY_DSN=https://your_sentry_dsn@o123456.ingest.sentry.io/123456

# ─────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────

# Secret for authenticating Vercel cron job requests
# Generate with: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here
